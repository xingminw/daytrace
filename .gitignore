# Python caches / test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local runtime data and private traces
data/
events/
logs/
outputs/
*.sqlite
*.sqlite-*
*.db
*.jsonl

# Local Feishu Drive sync state (per-machine ledger, not source of truth)
.daytrace/

# Claude Code / agent local state (settings, worktrees, launch.json, etc.)
.claude/

# Inbox staging (per-machine; contents already covered by *.jsonl above
# but the directory tree itself shouldn't be tracked either)
inbox/

# Local screenshots / media captures
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.mp4

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Local environment / secrets
.env
.env.*
!.env.example

# Generated launchd / cron config — they embed live API keys
ops/*.plist
ops/*-local.*
