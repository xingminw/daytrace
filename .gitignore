# Python caches / test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local runtime data and private traces
data/
events/
logs/
outputs/
*.sqlite
*.sqlite-*
*.db
*.jsonl

# Local Feishu Drive sync state (per-machine ledger, not source of truth)
.daytrace/

# Claude Code / agent local state (settings, worktrees, launch.json, etc.)
.claude/

# Inbox staging + per-device archive mirror (per-machine runtime data,
# not source). `*.jsonl` above catches event files but manifest .json
# files and the directory trees themselves also shouldn't be tracked.
inbox/
archive/

# Local screenshots / media captures
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.mp4

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Local environment / secrets
.env
.env.*
!.env.example

# Generated launchd / cron config — they embed live API keys
ops/*.plist
ops/*-local.*

# Feishu drive folder tokens — created on first upload, machine-local
config/feishu_drive.yaml
