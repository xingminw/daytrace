# Python caches / test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# All runtime state — single bucket. Everything DayTrace writes goes
# under data/: SQLite, inbox staging, per-device archive mirrors, logs,
# rendered reports, weekly AI cache. None of it is source of truth for
# the code, all of it is per-machine.
data/

# Database files that might sit elsewhere during local poking
*.sqlite
*.sqlite-*
*.db

# Raw event JSONL anywhere on disk
*.jsonl

# Claude Code / agent local state (settings, worktrees, launch.json, etc.)
.claude/

# Local screenshots / media captures
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.mp4

# OS / editor noise
.DS_Store
.idea/
.vscode/

# Secrets — DayTrace reads from ~/.daytrace/secrets.env (outside the repo);
# these are the just-in-case patterns.
.env
.env.*
!.env.example

# Feishu drive folder tokens — auto-generated on first upload, machine-local
config/feishu_drive.yaml
